# InnoMate Web 환경 변수
# cp .env.example .env.local 후 값을 입력하세요. (.env.local은 git에 커밋 금지)

# --- OpenAI (사내 프록시 URL 사용 가능) ---
# 사내 전용 URL이 있으면 여기에 입력 (예: https://ai-gateway.lginnotek.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key

# 기본 채팅 모델
OPENAI_MODEL=gpt-5.5

# --- 저장소 ---
# SQLite DB 파일 경로 (기본: web/data/innomate.db)
# INNOMATE_DB_PATH=./data/innomate.db
