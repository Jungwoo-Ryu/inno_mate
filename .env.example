# InnoMate 환경 변수
# 이 파일을 복사해 `.env`로 저장한 뒤 값을 입력하세요.
# `.env`는 git에 커밋하지 마세요.
#
# cp .env.example .env
#
# API 키 우선순위: .env > electron/envConfig.ts 하드코딩 > config.json
# UI에서 저장하면 프로젝트 .env(개발) + userData/.env(앱)에 자동 기록됩니다.

# --- AI Provider (하나만 설정) ---
# OpenAI (사내 게이트웨이 URL이 있으면 OPENAI_BASE_URL에 입력)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://ai-gateway.lginnotek.com/v1

# Gemini (Google AI Studio)
# GEMINI_API_KEY=your-gemini-api-key
# INNOMATE_API_PROVIDER=gemini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# INNOMATE_API_PROVIDER=anthropic

# --- Agent (선택) ---
# INNOMATE_AGENT_MODEL=gemini-3.5-flash

# --- PoC: 로컬 OCR 모드 (기본 활성) ---
# 스크린샷 실행 시 LLM 대신 tesseract 로컬 OCR 결과만 표시
# INNOMATE_POC_OCR=1
# LLM Agent로 되돌리려면: INNOMATE_POC_OCR=0

# --- G-portal POC 로그인 (system 계정) ---
# GPORTAL_URL=https://gportal.example.com
# GPORTAL_USERNAME=your_system_account_id
# GPORTAL_PASSWORD=your_system_account_password

# --- G-portal 어댑터: stub (기본) | playwright | api ---
# GPORTAL_ADAPTER=stub

# --- InnoMate 웹 포털 (에이전트 레지스트리 sync) ---
# INNOMATE_WEB_URL=http://localhost:3000
# --- 자동 업데이트 (패키징된 앱, 선택) ---
# GH_TOKEN=your_github_token
