# InnoMate 환경 변수
# 이 파일을 복사해 `.env`로 저장한 뒤 값을 입력하세요.
# `.env`는 git에 커밋하지 마세요.
#
# cp .env.example .env

# --- OpenAI (필수) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- G-portal POC 로그인 (system 계정) ---
GPORTAL_URL=https://gportal.lginnotek.com
GPORTAL_USERNAME=your_system_account_id
GPORTAL_PASSWORD=your_system_account_password

# --- G-portal 어댑터: stub (기본) | playwright | api ---
# GPORTAL_ADAPTER=stub
# GPORTAL_API_BASE_URL=https://gportal-api.lginnotek.com

# --- Agent (선택) ---
# INNOMATE_AGENT_MODEL=gpt-4o

# --- 자동 업데이트 (패키징된 앱, 선택) ---
# GH_TOKEN=your_github_token
